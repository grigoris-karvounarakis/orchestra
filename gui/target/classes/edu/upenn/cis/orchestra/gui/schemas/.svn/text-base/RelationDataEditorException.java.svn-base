package edu.upenn.cis.orchestra.gui.schemas;

public class RelationDataEditorException extends Exception {

	public static final long serialVersionUID = 1L;

	public RelationDataEditorException (Throwable ex)
	{
		super (ex);
	}
	
	public RelationDataEditorException (String msg)
	{
		super (msg);
	}
	
}
