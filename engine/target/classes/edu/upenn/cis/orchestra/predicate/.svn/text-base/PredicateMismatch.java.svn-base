package edu.upenn.cis.orchestra.predicate;

import edu.upenn.cis.orchestra.datamodel.Type;

public class PredicateMismatch extends Exception {
	private static final long serialVersionUID = 1L;
	
	PredicateMismatch(Type t1, Type t2) {
		super("Attempt to create a predicate comparing values of types " +
				t1 + " and " + t2);
	}
}
