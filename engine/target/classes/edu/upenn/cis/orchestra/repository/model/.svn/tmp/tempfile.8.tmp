import edu.upenn.cis.orchestra.repository.model.beans.ScRelationBean;
import edu.upenn.cis.orchestra.repository.model.beans.SchemaBean;
import edu.upenn.cis.orchestra.repository.model.exceptions.DuplicateRelationIdException;
import edu.upenn.cis.orchestra.repository.model.exceptions.InvalidBeanException;
import edu.upenn.cis.orchestra.repository.model.exceptions.UnknownRefFieldException;
import edu.upenn.cis.orchestra.util.DomUtils;

/****************************************************************
 * Schema definition
 * @author Olivier Biton
 *****************************************************************
 */
public class Schema 
{
   /** Schema id. Should be unique for a given peer, unicity not managed in this class */
   private String _schemaId;
   /** Schema description */
   private String _description;

   /** 
    * List of relations stored in this schema. The id used in the map is the relation name
    * @see ScRelation#getRelId()
    * @see ScRelation#getRelId(String, String, String)
    */
   protected Map<String,ScRelation> _relations = new HashMap<String,ScRelation>();
   

   
   /**
    * Creates a new schema
    * @param schemaId Schema id. Should be unique for a given peer, unicity not managed in this class
    * @param description Schema description
    * @roseuid 449AE40F0109
    */
   public Schema(String schemaId, String description) 
   {
	   _schemaId = schemaId;
	   _description = description;
   }
 
   
   /**
    * Create a new schema from its bean representation
    * @param schemaBean Bean describing the schema
    * @throws InvalidBeanException If one of the subproperties 
    *   is an invalid bean
    */
   public Schema(SchemaBean schemaBean)
   				throws InvalidBeanException
   {
	   _schemaId = schemaBean.getSchemaId();
	   _description = schemaBean.getDescription();
	   Map<ScRelationBean, ScRelation> oldNew = new HashMap<ScRelationBean, ScRelation> ();
	   for (ScRelationBean relB : schemaBean.getRelations())
	   {
		   ScRelation rel = new ScRelation (relB);
		   try
		   {
			   addRelation(rel);
			   oldNew.put(relB, rel);
		   } catch (DuplicateRelationIdException ex)
		   {
			   throw new InvalidBeanException (schemaBean, ex.getMessage());
		   }
	   }
	   for (Map.Entry<ScRelationBean, ScRelation> entry : oldNew.entrySet())
		   entry.getValue().loadForeignKeys(entry.getKey(), this);
   }
   
   /**
    * Creates a deep copy of a given schema
    * @param schema Schema to copy
    */
   public Schema (Schema schema)
   {
	   _schemaId = schema.getSchemaId();
	   _description = schema.getDescription();
	   Map<ScRelation,ScRelation> oldNewRel = new HashMap<ScRelation, ScRelation> ();
	   for (ScRelation rel : schema.getRelations())
	   {
		   ScRelation relNew = rel.deepCopy();
		   try
		   {
		   		addRelation(relNew);
		   } catch (DuplicateRelationIdException ex)
		   {
			   //TODO: Logger
			   System.out.println ("Duplicate relation id should not occur in deep copy! : " + ex.getMessage());
			   ex.printStackTrace();
		   }
		   oldNewRel.put(rel, relNew);
	   }
	   for (Map.Entry<ScRelation, ScRelation> entry : oldNewRel.entrySet())
		   entry.getValue().deepCopyFks(entry.getKey(), this);
   }
   


   /**
    * Add a new relation to this schema
    * @param rel New relation
    * @throws DuplicateRelationIdException If the relation name is already used for another 
    * 					relation in this schema
    */
   public void addRelation (ScRelation rel)
   					throws DuplicateRelationIdException
   {
	   if (_relations.containsKey(rel.getName()))
		   throw new DuplicateRelationIdException (rel.getName(), getSchemaId());		   
	   _relations.put(rel.getName(), rel);
   }
   

   
   /**
    * Get the relations contained in this schema
    * @return Collection of relations
    * @roseuid 449AEDB30109
    */
   public Collection<ScRelation> getRelations() 
   {
      return _relations.values();
   }
   
   /**
    * Get a relation from it's name
    * @param relName Relation name
    * @return The relation, if found TODO: exception if doesn't exist
    * @roseuid 449AEDC001A5
    */
   public ScRelation getRelation(String relName) throws RelationNotFoundException
   {
	   //TODO: Exception if relId unknown
	   if(_relations.containsKey(relName)){
		   return _relations.get(relName);
	   }else{
		   throw new RelationNotFoundException("Relation " + relName + "not found in Schema " + getSchemaId());
	   }
   }
   
   /**
    * Get a relation found from it's underlying database characteristics :
    * dbCatalog, dbSchema and dbRelationName
    * @param dbCatal Database catalog containing the table
    * @param dbSchema Database schema containing the table
    * @param dbRelName Database table name
    */
   public ScRelation getRelation (String dbCatal, String dbSchema, String dbRelName)
   {
	   ScRelation res = null;
	   Iterator<ScRelation> itRels = getRelations().iterator();
	   while (itRels.hasNext() && res == null)
	   {
		   ScRelation rel = itRels.next();
		   if (compareNullStr(dbCatal, rel.getDbCatalog())
				   && compareNullStr(dbSchema, rel.getDbSchema())
				   && dbRelName.equals(rel.getDbRelName()))
			   res = rel;
	   }
	   return res;
	   // TODO: exception if not found
   }
   
   private boolean compareNullStr (String str1, String str2)
   {
	   boolean equal = true;
	   
	   if (str1 != null)
		   equal = (str1.equals(str2));
	   else
		   equal = (str2 == null);
	   
	   return equal;

   }
   
   
   //TODO: incoherence between DB which considers that relation name is unique for each schema and this 
   // class. Todo: distinguish a unique relation name from the fully qualified db name. 
   
   /**
    * Test if a relation name exists in this schema
    * @param relId Relation name
    * @return true if it does exists
    */
   public boolean existsRelation (String relName)
   {
	   return _relations.containsKey(relName);
   }
   
   /**
    * Get the schema id
    * @return Schema id
    * @roseuid 44AD2C9700CB
    */
   public String getSchemaId() 
   {
	   return _schemaId;
   }
   
   /**
    * Get the schema description
    * @return Schema description
    * @roseuid 44AD2CB10177
    */
   public String getDescription() 
   {
	   return _description;
   }
   
   /**
    * Set the schema description
    * @param description New description
    */
   public void setDescription (String description)
   {
	   _description  = description;
   }
   
   /**
    * Returns a description of the schema, , conforms to the 
    * flat file format defined in <code>RepositoryDAO</code>
    * @return Schema description
    */   
   public String toString ()
   {
	   return toString (0);
   }
   
   /**
    * Returns a description of the schema, conforms to the 
    * flat file format defined in <code>RepositoryServer</code>.<BR>
    * Description is indented according to the nb of tabulations
    * @param nbTabs Number of tabulations in indentation
    * @return Schema description
    */   
   protected String toString (int nbTabs)
   {
	   
	   StringBuffer buff = new StringBuffer (); 
	   
	   for (int i = 0 ; i < nbTabs ; i++)
		   buff.append("\t");

	   buff.append ("SCHEMA ");
	   buff.append (getSchemaId());
	   buff.append (" \"" + getDescription().replace("\n", "\\n") + "\"\n");

	   for (int i = 0 ; i < nbTabs ; i++)
		   buff.append("\t");
	   buff.append("\tRELATIONS\n");
	   
	   for (ScRelation rel : getRelations())
		   buff.append(rel.toString(nbTabs+2) + "\n");
	   
	   return buff.toString();	   
   }
   
   /**
    * Creates a bean representation for this schema
    * @return The schema bean
    */
   public SchemaBean toBean ()
   {
	   SchemaBean schemaB = new SchemaBean ();
	   // Create the list of relations beans
	   List<ScRelationBean> relationsBeans = new ArrayList<ScRelationBean> ();
	   for (ScRelation rel : getRelations())
		   relationsBeans.add (rel.toBean ());
	   schemaB.setRelations(relationsBeans);
	   /* Copy the bean simple properties */
	   BeanUtils.copyProperties(this, schemaB, new String[] {"relations"});
	   
	   return schemaB;
	   
	   //return new SchemaBean(getSchemaId(), getDescription(), relationsBeans);
   }
 
   /**
    * Get a deep copy of this schema.
    * @return Deep copy
    * @see Schema#Schema(Schema)
    */
   public Schema deepCopy ()
   {
	   return new Schema (this);
   }

   public void serialize(Document doc, Element schema) {
	   schema.setAttribute("name", _schemaId);
	   schema.setAttribute("description", _description);
	   for (String key : _relations.keySet()) {
		   Element rel = DomUtils.addChild(doc, schema, "relation");
		   ScRelation r = _relations.get(key);
		   r.serialize(doc, rel);
		   for (ScForeignKey fk : r.getForeignKeys()) {
			   Element foreignkey = DomUtils.addChild(doc, schema, "foreignkey");
			   fk.serialize(doc, foreignkey);
		   }
	   }
   }

   public static Schema deserialize(Element schema) throws DuplicateRelationIdException, UnknownRefFieldException, XMLParseException {
	   String id = schema.getAttribute("name");
	   String desc = schema.getAttribute("description");
	   Schema s = new Schema(id, desc);
	   for (Element rel : DomUtils.getChildElementsByName(schema, "relation")) {
		   ScRelation r = ScRelation.deserialize(rel);
		   s.addRelation(r);
	   }
	   for (Element key : DomUtils.getChildElementsByName(schema, "foreignkey")) {
		   ScForeignKey fk = ScForeignKey.deserialize(s, key);
		   ScRelation rel = fk.getRelation();
		   rel.addForeignKey(fk);
	   }
	   return s;
   }
}
