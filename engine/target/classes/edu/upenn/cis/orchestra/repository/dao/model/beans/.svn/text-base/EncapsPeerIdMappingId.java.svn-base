package edu.upenn.cis.orchestra.repository.dao.model.beans;

public class EncapsPeerIdMappingId {

	private String _peerId;
	private String _mappingId;
	
	public EncapsPeerIdMappingId ()
	{
		
	}
	
	public EncapsPeerIdMappingId (String peerId, String mappingId)
	{
		_peerId = peerId;
		_mappingId = mappingId;
	}
	
	public String getMappingId() {
		return _mappingId;
	}
	public void setMappingId(String mappingId) {
		this._mappingId = mappingId;
	}
	public String getPeerId() {
		return _peerId;
	}
	public void setPeerId(String peerId) {
		this._peerId = peerId;
	}
	
	
}
