	/**
	 * Get a fresh version of this atom value, that is a version whose variables 
	 * are renamed so that they are not mixed up with original variables composition
	 * @param freshenVars old/new names for already freshen variables
	 * @param asNewObject If true the a new freshen atom will be returned, if false this atom will be
	 * 					freshen and then returned 
	 * @return Freshen atom
	 */
	public ScMappingAtom fresh(Map<String, String> freshenVars, boolean asNewObject) {
		ScMappingAtom atom;

		List<ScMappingAtomValue> newValues = new ArrayList<ScMappingAtomValue> ();
		for (ScMappingAtomValue val : getValues())
			newValues.add(val.fresh(freshenVars, asNewObject));
		
		if (asNewObject){
			atom = new ScMappingAtom(this, newValues);

			atom.setType(getType());
			atom.setNeg(isNeg());
			if(allStrata())
				atom.setAllStrata();
			return atom;
		}else{
			_values = newValues;

			return this;
		}
	}	

	
	/**
	 * Substitute all occurences of <code>valInit</code> with <code>valRepl</code>
	 * in the atom values
	 * @param oldVal Value to be replaced
	 * @param newVal New value
	 */	
	public void substitute (ScMappingAtomValue oldVal, 
								ScMappingAtomValue newVal)
	{
		for (int i = 0 ; i < _values.size() ; i++)
		{
			ScMappingAtomValue value = _values.get(i);
			// If the atom value is to be replaced ...
			if (value.equals(oldVal) && oldVal.equals(value))
			{
				_values.remove(i);
				_values.add(i, newVal);
			}
			// Else replace any occurence of oldVal inside the atom sub-atoms if any
			else
				value.substitute(oldVal, newVal);
		}
	}
	
	protected void renameVariables (String extension)
	{
		for (ScMappingAtomValue val : getValues())
			val.renameVariable(extension);
	}

	public Map<String, ScMappingAtomValue> varHomomorphism(ScMappingAtom other){
		HashMap<String, ScMappingAtomValue> varmap = new HashMap<String, ScMappingAtomValue> ();
		if(getRelationContext().equals(other.getRelationContext())){
			for(int i = 0; i < getValues().size(); i++){
				ScMappingAtomValue v = getValues().get(i);
				if(v instanceof ScMappingAtomValVariable){
					ScMappingAtomValVariable var = (ScMappingAtomValVariable)v;
					varmap.put(var.getName(), other.getValues().get(i));
				}else if(v instanceof ScMappingAtomValConst){
					ScMappingAtomValConst c = (ScMappingAtomValConst)v;
					ScMappingAtomValue v2 = other.getValues().get(i);
					if(v2 instanceof ScMappingAtomValConst){
						ScMappingAtomValConst c2 =(ScMappingAtomValConst)v2;
						if(!c2.equals(c)){
							return null;
						}
					}else{
						return null;
					}
				}else{
					return null;
				}
			}
			return varmap;
		}else{
			return null;
		}
	}
	
	public void substituteVars(Map<String, ScMappingAtomValue> varmap){
    	
    	for(int i = 0; i < getValues().size(); i++){
    		ScMappingAtomValue v = getValues().get(i);
    	
    		if(v instanceof ScMappingAtomValVariable){
    			ScMappingAtomValVariable var = (ScMappingAtomValVariable)v;
    			if(varmap.containsKey(var.getName())){
    				getValues().remove(i);
    				getValues().add(i, varmap.get(var.getName()));
    			}
    		}else if (v instanceof ScMappingAtomValConst){ 
    			
    		} else { // Should do smth else for skolems 
    			throw new RuntimeException("Cannot substitute non-variable: " + v.toString());
    			//System.out.println(1/0);
    		}
    	}
    }
    
    public boolean samePattern(ScMappingAtom other){
    	if((!getRelationContext().equals(other.getRelationContext())) || (getValues().size() != other.getValues().size()))
    		return false;	
    	
    	for(int i = 0; i < getValues().size(); i++) {
    		ScMappingAtomValue v = getValues().get(i);
    		ScMappingAtomValue ov = other.getValues().get(i);
    		
    		if(((v instanceof ScMappingAtomValVariable) && !(ov instanceof ScMappingAtomValVariable)) ||
    		   ((v instanceof ScMappingAtomValConst) && !(ov instanceof ScMappingAtomValConst))) {
    			return false;
    		} else if ((v instanceof ScMappingAtomValConst) && (ov instanceof ScMappingAtomValConst)) {
    			ScMappingAtomValConst vc = (ScMappingAtomValConst)v;
    			ScMappingAtomValConst ovc = (ScMappingAtomValConst)ov;
    			
    			if(!vc.equals(ovc))
    				return false;
    		} // else Skolem?
    	}
    	
    	return true;
    }
    
    public void renameExistentialVars(ScMapping r){
    	for(ScMappingAtomValue val : getValues()){
    		if(val instanceof ScMappingAtomValVariable){
    			if(!r.isDistinguished((ScMappingAtomValVariable) val))
    				((ScMappingAtomValVariable) val).setName(ScMapping.getFreshAutogenVariableName());
    		}else if(val instanceof ScMappingAtomValConst){
    			// do nothing?
   			}else{
    			//System.out.println(1/0);
        		throw new RuntimeException("Cannot rename non-variable: " + val.toString());
    		}
    	}
    }
    
    public void serialize(Document doc, Element atom) {
    	StringBuffer buf = new StringBuffer(_relationContext.toString());
    	buf.append("(");
    	boolean first = true;
    	for (ScMappingAtomValue value : _values) {
    		if (first) {
    			first = false;
    		} else {
    			buf.append(", ");
    		}
    		buf.append(value.toString());
    	}
    	buf.append(")");
    	atom.setTextContent(buf.toString());
    }
    
    public static ScMappingAtom deserialize(OrchestraSystem catalog, Element atom, Holder<Integer> counter) throws XMLParseException {
    	String text = atom.getTextContent().trim();
    	try {
    		UntypedAtom u = UntypedAtom.parse(text, counter);
    		return u.getTyped(catalog);
    	} catch (ParseException e) {
    		throw new XMLParseException(e);
    	} catch (RelationNotFoundException e) {
    		throw new XMLParseException(e);
    	}
    }
}
