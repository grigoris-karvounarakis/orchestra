package edu.upenn.cis.orchestra.dbms.sql.generation;

import com.experlog.zql.ZSelectItem;

/**
 * SqlSelectItem: an item in the SELECT part of an SQL query.
 * (The SELECT part of a query is a Vector of SqlSelectItem).
 * 
 * @author gkarvoun
 * 
 */
public class SqlSelectItem extends ZSelectItem {

	public SqlSelectItem() {
		super();
	}

	public SqlSelectItem(String fullname) {
		super(fullname);
	}

};

