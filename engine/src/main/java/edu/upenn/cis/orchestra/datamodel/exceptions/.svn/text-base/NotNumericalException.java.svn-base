package edu.upenn.cis.orchestra.datamodel.exceptions;

import edu.upenn.cis.orchestra.datamodel.Type;


public class NotNumericalException extends Exception {
	private static final long serialVersionUID = 1L;
	
	public NotNumericalException(Type t) {
		super(t + " is not a numerical type");
	}
}