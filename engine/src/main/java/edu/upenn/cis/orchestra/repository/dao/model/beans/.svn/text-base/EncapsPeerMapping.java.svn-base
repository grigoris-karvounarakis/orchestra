package edu.upenn.cis.orchestra.repository.dao.model.beans;

import edu.upenn.cis.orchestra.repository.model.beans.PeerBean;
import edu.upenn.cis.orchestra.repository.model.beans.ScMappingBean;

public class EncapsPeerMapping {

	private PeerBean _peer;
	private ScMappingBean _mapping;
	
	public EncapsPeerMapping ()
	{
		super ();
	}

	public EncapsPeerMapping (PeerBean peer, ScMappingBean mapping)
	{
		super ();
		_peer = peer;
		_mapping = mapping;
	}	
	
	public ScMappingBean getMapping() {
		return _mapping;
	}
	public void setMapping(ScMappingBean mapping) {
		this._mapping = mapping;
	}
	public PeerBean getPeer() {
		return _peer;
	}
	public void setPeer(PeerBean peer) {
		this._peer = peer;
	}
	
	
	
}
