	protected DatalogSequence preInsertion(boolean useProvenance) {
		DatalogSequence ret;
		ret = new DatalogSequence(false, true);
        List<Rule> init = new ArrayList<Rule>();
        
        init.addAll(copyRelationList(getEdbs(), AtomType.NEW, AtomType.NONE));
//        init.addAll(copyRelationList(getEdbs(), AtomType.NEW, AtomType.INS));
        init.addAll(copyRelationList(getIdbs(), AtomType.NEW, AtomType.NONE));
        init.addAll(copyRelationList(getMappingRelations(), AtomType.NEW, AtomType.NONE));
       
        ret.add(new NonRecursiveDatalogProgram(init));
		return ret;
	}
	
	protected DatalogSequence postInsertion(boolean useProvenance) {
		DatalogSequence ret;
		ret = new DatalogSequence(false, true);
        List<Rule> post = new ArrayList<Rule>();
        
        post.addAll(copyRelationList(getMappingRelations(), AtomType.NEW, AtomType.INS));
        ret.add(new NonRecursiveDatalogProgram(post));

//		I don't think this should be different for DRed        
//        ret.add(_dr.applyDeltasToBase(DRed));
        ret.add(applyDeltasToBase(false, getMappingRelations(), getEdbs(), getIdbs()));
        ret.add(cleanupRelations(AtomType.INS, getMappingRelations(), getEdbs(), getIdbs()));
		return ret;
	}
    
	/**
	 * Creates the datalog program sequence (including copies/deletions) to
	 * apply a set of insertions.
	 * 
	 */
    protected DatalogSequence createInsertionProgramSequence(boolean useProvenance) {
        DatalogSequence ret = new DatalogSequence(false, true);

        ret.add(new NonRecursiveDatalogProgram(copyRelationList(getEdbs(), AtomType.NEW, AtomType.INS)));
//        ret.add(edbDeltaApplicationRules(true));
        
        
//      Map in data from pure-EDB relations, i.e. those not in the head
//      of any rule
//		ret.add(edbDeltaApplicationRules(true));

    	List<Rule> mainloop = new ArrayList<Rule>();

    	for(int i = 0; i < getMappingRules().size(); i++) {
//    		mainloop.addAll(insertionRules(getMappingRules().get(i), true));
    		mainloop.addAll(insertionRules(getMappingRules().get(i), false));
    	}
    	for(int i = 0; i < getMappingProjectionRules().size(); i++) {
//    		mainloop.addAll(insertionRules(getMappingProjectionRules().get(i), true));
    		mainloop.addAll(insertionRules(getMappingProjectionRules().get(i), false));
    	}
    	
        mainloop.addAll(idbDeltaApplicationRules(true, false));
        
        ret.add(new RecursiveDatalogProgram(mainloop));

        return ret;
	}	
	
	//Note: some atoms are shared between different rules. If these atoms need to be modified 
	// independently in another process, we should deep copy all atoms.
	
	/**
	 * Generate all insertion delta rules for a given rule 
	 * @param r Rule for which to generate the delta rules
	 * @return Delta rules
	 */
	private static List<Rule> insertionRules (Rule r, boolean replaceValsWithNullVals)
    //private static List<DatalogProgram> insertionRules (Rule r)
	{
		AtomType type = AtomType.INS;
		
		ScMappingAtom head = new ScMappingAtom (r.getHead(), type);
		
		List<ScMappingAtom> body = new ArrayList<ScMappingAtom> ();
		for (ScMappingAtom atom : r.getBody())
			body.add (new ScMappingAtom (atom, AtomType.NONE));
		
		List<Rule> deltas = new ArrayList<Rule> ();
		//List<DatalogProgram> deltas = new ArrayList<DatalogProgram> ();
		int size = body.size();
		if(body.get(size - 1).isNeg()){
			size = size - 1;
		}
		
		int lastInd = -1;
		for (int i = 0 ; i < size ; i++)
		{
			while(body.get(i).isSkolem() && i < size){
				i++;
			}
			
			if (lastInd >= 0){
				body.set(lastInd, new ScMappingAtom(body.get(i-1), AtomType.NEW));
			}
			body.set (i, new ScMappingAtom(body.get(i), type));
			lastInd = i;
			
			Rule deltaRule = new Rule(head, body);
//			if(replaceValsWithNullVals)
				deltaRule.setReplaceValsWithNullValues();
			deltas.add(deltaRule);
			//deltas.add(new SingleRuleDatalogProgram(new Rule(head, body)));
		}
		return deltas;
	}
	
	
