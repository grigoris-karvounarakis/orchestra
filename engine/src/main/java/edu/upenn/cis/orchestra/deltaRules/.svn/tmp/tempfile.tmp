/**
 * Rule generator for insertion delta rules
 * 
 * @author zives, gkarvoun
 *
 */
public class InsertionDeltaRuleGen extends DeltaRuleGen {
	public InsertionDeltaRuleGen (OrchestraSystem sys)//DeltaRules dr)
	{
		super(sys);//dr);
	}

	public InsertionDeltaRuleGen (OrchestraSystem sys/*DeltaRules dr*/, boolean DRed, boolean useProvenance)
	{
		super(sys, DRed, useProvenance);
	}

	@Override
	protected List<DatalogSequence> computeRules(boolean DRed, boolean useProvenance) {
		List<DatalogSequence> ret = new ArrayList<DatalogSequence>();
		
		if (Config.getOuterUnion()){
			ret.add(preOUInsertion(!DRed));
			ret.add(createOUInsertionProgramSequence(!DRed));
			ret.add(postOUInsertion(!DRed));
		}else{
			ret.add(preInsertion(!DRed));
			ret.add(createInsertionProgramSequence(!DRed));
			ret.add(postInsertion(!DRed));
		}
		return ret;
	}
	
	@Override
	public long execute(DatalogEngine de) {
//		dbCn.commit();
//		_provenancePrep.activateNotLoggedInitDB2(dbCn, system);
				
//			dbCn.commit();
		//_provenancePrep.collectStatistics(dbCn, system);
		
		
		// Map to each field it's database datatype. This is necessary 
		// because DB2 needs to cast null values!!!
		try {	
			Calendar before;
			Calendar after;
			long time;
			long retTime;
			
			//if(!"yes".equals(System.getProperty("skipins"))){
			System.out.println("=====================================================");
			System.out.println("INSERTIONS");
			System.out.println("=====================================================");
			
			if(de._sql instanceof SqlDb)
				((SqlDb)de._sql).activateRuleBasedOptimizer();
			
			List<DatalogSequence> insProg = getCode();

			before = Calendar.getInstance();
			de.evaluatePrograms(insProg.get(0));
			after = Calendar.getInstance();
			time = after.getTimeInMillis() - before.getTimeInMillis();
			System.out.println("INSERTION PREP TIME: " + time + "msec");		
			
			commitAndReset(de);
			
			before = Calendar.getInstance();
			de.evaluatePrograms(insProg.get(1));
			after = Calendar.getInstance();
			time = after.getTimeInMillis() - before.getTimeInMillis();
			System.out.println("INCREMENTAL INSERTION ALG TIME (INCL COMMIT): " + time + "msec");
	        System.out.println("TIME SPENT FOR COMMIT AND LOGGING DEACTIVATION: " + de.logTime() + "msec");
			System.out.println("EXP: NET INSERTION TIME: " + (time - de.logTime()) + "msec");


			SqlEngine.insTimes.add(new Long(time - de.logTime()));
			retTime = time - de.logTime();
			
			commitAndReset(de);
			
			before = Calendar.getInstance();
			de.evaluatePrograms(insProg.get(2));
			after = Calendar.getInstance();
			time = after.getTimeInMillis() - before.getTimeInMillis();
			System.out.println("POST INSERTION TIME: " + time + "msec");
	
			commitAndReset(de);
			

			return retTime;
			
		} catch (Exception ex)
		{
			ex.printStackTrace();
			return -1;
		}
	}

	protected DatalogSequence preOUInsertion(boolean useProvenance) {
		DatalogSequence ret;
		ret = new DatalogSequence(false, true);
        List<Rule> init = new ArrayList<Rule>();
        
        init.addAll(copyRelationList(getEdbs(), AtomType.NEW, AtomType.NONE));
//        init.addAll(copyRelationList(getEdbs(), AtomType.NEW, AtomType.INS));
        init.addAll(copyRelationList(getIdbs(), AtomType.NEW, AtomType.NONE));
        init.addAll(copyRelationList(getOuterUnionMappingRels(), AtomType.NEW, AtomType.NONE));
       
        ret.add(new NonRecursiveDatalogProgram(init));
		
		return ret;
	}
	
	protected DatalogSequence postOUInsertion(boolean useProvenance) {
		DatalogSequence ret;
		ret = new DatalogSequence(false, true);
		List<Rule> post = new ArrayList<Rule>();
        
        post.addAll(copyRelationList(getOuterUnionMappingRels(), AtomType.NEW, AtomType.INS));
        ret.add(new NonRecursiveDatalogProgram(post));

//		I don't think this should be different for DRed        
//        ret.add(_dr.applyDeltasToBase(DRed));
        
        ret.add(applyDeltasToBase(false, getOuterUnionMappingRels(), getEdbs(), getIdbs()));
        ret.add(cleanupRelations(AtomType.INS, getOuterUnionMappingRels(), getEdbs(), getIdbs()));
        
		return ret;
	}
	
    protected DatalogSequence createOUInsertionProgramSequence(boolean useProvenance) {
		List<Rule> mainloop = new ArrayList<Rule>();
        DatalogSequence ret = new DatalogSequence(false, true);
        
        
        if (!useProvenance)
        	return createInsertionProgramSequence(!useProvenance);

        ret.add(new NonRecursiveDatalogProgram(copyRelationList(getEdbs(), AtomType.NEW, AtomType.INS)));
        
        // Map in data from pure-EDB relations, i.e. those not in the head
        // of any rule
		//ret.add(_dr.provenanceEdbDeltaApplicationRules(true));
        
        //if (_dr == null)
        //	System.err.println("No delta rules");
        
        if (getMappingRules() == null)
        	System.err.println("No OU rules");

        for (Rule r : getMappingRules()) {
	        mainloop.addAll(insertionRules(r, true));
        }

        for (Rule r : getMappingProjectionRules()) {
	        mainloop.addAll(insertionRules(r, false));
        }
        
//        for (Rule r : _dr.getOuterUnionPopulationRules()) {
//	        mainloop.addAll(insertionRules(r));
//        }
        
        mainloop.addAll(idbDeltaApplicationRules(true, false));
        
        ret.add(new RecursiveDatalogProgram(mainloop));
		
        return ret;
	}	
	
