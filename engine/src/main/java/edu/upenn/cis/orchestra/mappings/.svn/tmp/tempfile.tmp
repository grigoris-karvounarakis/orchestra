        // assume for now all parameters are plain variables
        StringBuffer buf = new StringBuffer();
        
        for (int i = 0 ; i <= sk.getParams().size() ; i++)
        	buf.append ("CONCAT(");
        
        buf.append("'" + sk.getName() + "('");
        boolean f = true;
        for (ScMappingAtomValue val : sk.getParams()) 
        {
        	buf.append (",");
        	buf.append ((f?"":"CONCAT(',' ,"));
        	if (val instanceof ScMappingAtomValVariable)
        	{
	        	buf.append ("CONCAT(CONCAT(");
	        	buf.append ("'''', " + _varmap.get(val.toString()));
	        	buf.append ( "), '''')");
        	}
        	else if (val instanceof ScMappingAtomValConst)
        	{
        		buf.append(val.toString());
        	}
        	else if (val instanceof ScMappingAtomValSkolem)
        		buf.append (skolemExpr((ScMappingAtomValSkolem)val));
        		
        	
        	buf.append ((f?"":")"));
        	f = false;        	        	
        	buf.append (")");
        }
        buf.append(",')')");
        
        
        return buf.toString();
    }*/
    
    public Rule deepCopy(){
    	List<ScMappingAtom> newbody = new ArrayList<ScMappingAtom> ();
    	for(ScMappingAtom a : getBody())
    		newbody.add(a.deepCopy());
    	Rule res = new Rule(getHead().deepCopy(), newbody, onlyKeyAndNulls());
    	res._clearNcopy = clearNcopy();
    	res._deleteFromHead = deleteFromHead();
//    	res._headEmpty = headEmpty();
    	res._onlyKeyAndNulls = onlyKeyAndNulls();
    	return res;
    }
    
    public void substituteVars(Map<String,ScMappingAtomValue> varmap){
    	getHead().substituteVars(varmap);
    	for(ScMappingAtom a : getBody()){
    		a.substituteVars(varmap);
    	}
    }
    
    /*
     *  Greg: May overlap/provide the same functionality with composeWith ...
     */
    public List<Rule> substituteAtom(int pos, List<Rule> defs){
    	List<Rule> res = new ArrayList<Rule>();
    	Rule common = this.deepCopy();
    	
    	// Check if this leaves gap!
    	ScMappingAtom a = common.getBody().remove(pos);
    	
    	for(Rule def : defs){
//    		Map<String, ScMappingAtomValue> varmap = a.varHomomorphism(def.getHead());
    		Map<String, ScMappingAtomValue> varmap = def.getHead().varHomomorphism(a);
    		
    		if(varmap != null){
    			Rule newRule = common.deepCopy();
    			Rule newDef = def.deepCopy();
    			newDef.renameExistentialVars();
    			newDef.substituteVars(varmap);
    			newRule.getBody().addAll(newDef.getBody());
    			res.add(newRule);
    		}
    	}
    	return res;
    }
    
    public void renameExistentialVars(){
    	for(ScMappingAtom a : getBody()){
    		a.renameExistentialVars(this);
    	}
    }
    
    public List<Rule> invertForReachabilityTest(boolean invertEdbs, boolean invertOthers, List<ScRelationContext> edbs) {
		List<Rule> res = new ArrayList<Rule> ();
		
		for(ScMappingAtom a : getBody()){
			if(!a.isNeg()){
				if((invertEdbs && invertOthers) ||
						(edbs.contains(a.getRelationContext()) && invertEdbs) ||
						(!edbs.contains(a.getRelationContext()) && invertOthers)){
					ScMappingAtom newHead = a.deepCopy();
					newHead.setType(AtomType.INV);
					
					ScMappingAtom bodyAtom = getHead().deepCopy();
					bodyAtom.setType(AtomType.INV);
					List<ScMappingAtom> newBody = new ArrayList<ScMappingAtom> ();
					newBody.add(bodyAtom);

					/*
				boolean allFound = true;

				for(int i = 0; i < newHead.getValues().size() && allFound; i++){
					ScMappingAtomValue v = newHead.getValues().get(i);
					if (v instanceof ScMappingAtomValVariable){	
						ScMappingAtomValVariable var1 = (ScMappingAtomValVariable)v;
						boolean varFound = false;
						for(ScMappingAtomValue vv : bodyAtom.getValues()){
							if(vv instanceof ScMappingAtomValVariable){	
								ScMappingAtomValVariable var2 = (ScMappingAtomValVariable)vv;
								if(var1.getName().equals(var2.getName())){
									varFound = true;
									break;
								}
							}
						}
						allFound = allFound && varFound;
					}
				}

				if(!allFound){
					 */
					ScMappingAtom safeBody = newHead.deepCopy();
					safeBody.setType(AtomType.NEW);
					newBody.add(safeBody);
					//}
					res.add(new Rule(newHead, newBody, onlyKeyAndNulls()));
				}
			}
		}
		return res;
    
    }
    
    public static List<Rule> invertMappingForReachabilityTest(ScMapping mapping, boolean invertEdbs, boolean invertOthers, List<ScRelationContext> edbs) {
		List<Rule> res = new ArrayList<Rule> ();
		
		for(ScMappingAtom a : mapping.getBody()){
			if((invertEdbs && invertOthers) ||
					(edbs.contains(a.getRelationContext()) && invertEdbs) ||
					(!edbs.contains(a.getRelationContext()) && invertOthers)){
				ScMappingAtom newHead = new ScMappingAtom(a.deepCopy());
				newHead.setType(AtomType.INV);

				List<ScMappingAtom> newBody = new ArrayList<ScMappingAtom>();
				for(ScMappingAtom ma : mapping.getMappingHead()){
					ScMappingAtom bodyAtom = new ScMappingAtom(ma.deepCopy());
					bodyAtom.setType(AtomType.INV);;
