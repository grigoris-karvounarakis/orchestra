    protected HashMap<String,String> buildVarMapForAtom(ScMappingAtom a, int i, HashMap<String,String> oldmap, boolean buildNew) {
    	HashMap<String,String> newmap = new HashMap<String,String>();
    	HashMap<String,String> map;
    	
    	if(buildNew){
    		map = newmap;
    	}else{
    		map = oldmap;
    	}
    		
    	for (int j = 0; j < a.getValues().size(); j++) 
        {
    		 ScMappingAtomValue val = a.getValues().get(j);
        
    		 if (val instanceof ScMappingAtomValVariable)
    		 {
    			 if (!map.containsKey(val.toString())) {
    				 String value;
    				 if(i >= 0){
    					 value = "R" + i + "." + a.getRelation().getField(j).getName();
    				 }else{
    					 value = a.getRelation().getField(j).getName();
    				 }
    				 map.put(val.toString(), value);
    			 }
    		 }
        }
    	return map;
    }
    
    protected HashMap<String,String> buildVarMap() {
    	HashMap<String,String> varmap = new HashMap<String,String>();
        for (int i = 0; i < getBody().size(); i++) 
        {
        	ScMappingAtom a = getBody().get(i);
        	if(!a.isNeg())
        		buildVarMapForAtom(a, i, varmap, false);
        }
        return varmap;
    }    

    
    protected ZFromItem buildFromItem(ScMappingAtom a, int i){
		//ZFromItem f = new ZFromItem(a.getRelation().getFullQualifiedDbId());
		ZFromItem f = new ZFromItem(a.toString3());
		if(i >= 0)
			f.setAlias("R" + i);
		return f;
    }
       
    protected Vector<ZFromItem> buildFrom() {
        Vector<ZFromItem> vf = new Vector<ZFromItem>();
        int i = 0;
        for (ScMappingAtom a : getBody()) {
        	if(!a.isNeg()){
        		vf.add(buildFromItem(a, i++));
        	}else{
        		i++;
        	}
        }
        return vf;
    }

    protected ZExpression hack(ZConstant c1, ZConstant c2){
    	return(new ZExpression(ZExpression.OR,
    			new ZExpression(ZExpression.AND,
                               new ZExpression(ZExpression.IS_NULL, c1), 
                               new ZExpression(ZExpression.IS_NULL, c2)),
    	        new ZExpression(ZExpression.AND,
                               new ZExpression(ZExpression.IS_NOT_NULL, c1), 
                               new ZExpression(ZExpression.IS_NOT_NULL, c2))
    			)
    	);
    }
    protected ZExpression buildWhereForAtom(ScMappingAtom a, int i, Map<String,String> map, ZExpression expr){
       	
    	for (int j = 0; j < a.getValues().size(); j++) 
		{
    		//boolean comparable = a.getRelation().getField(j).getName().equals("KID");
    		boolean comparable = a.getRelation().getPrimaryKey().getFields().contains(a.getRelation().getField(j));
    		// Normal behaviour would be:
    		// boolean comparable = true;
    		
			ScMappingAtomValue val = a.getValues().get(j);
			String l;
			if(i >= 0){
				l = "R" + i + "." + a.getRelation().getField(j).getName();
			}else{
				l = a.getRelation().getField(j).getName();
			}
			if (val instanceof ScMappingAtomValConst) 
			{
				ZConstant c1 = new ZConstant(l, ZConstant.COLUMNNAME);
				ScMappingAtomValConst c = (ScMappingAtomValConst)val;
				
				// hack for experiments
				if(c.getValue() == null){
					expr = conjoin(expr, new ZExpression(ZExpression.IS_NULL, c1));
				}else{
					ZConstant c2 = new ZConstant(c.getValue(), ZConstant.STRING);
					//if(comparable){
						expr = conjoin(expr, new ZExpression(ZExpression.EQ, c1, c2));
					//}else{
						//expr = conjoin(expr, hack(c1,c2));
					//}
				}
			} 
			else if (val instanceof ScMappingAtomValVariable) 
			{
//				otherwise, this is just a projected out var in a negated clause
				if(map.containsKey(val.toString())){ 
					String n = map.get(val.toString());
					ZConstant c1 = new ZConstant(l, ZConstant.COLUMNNAME);
					ZConstant c2 = new ZConstant(n, ZConstant.COLUMNNAME);
					if (c1.toString().compareTo(c2.toString()) != 0) 
					{
						ZExpression exprLoc = null;
						if(comparable){
							exprLoc = new ZExpression(ZExpression.EQ, c1, c2);
						}else{
							//exprLoc = hack(c1,c2);
						}
						
						ZConstant c3 = new ZConstant(l + ModelConstants.LABEL_NULL_EXT, ZConstant.COLUMNNAME);
						ZConstant c4 = new ZConstant(n + ModelConstants.LABEL_NULL_EXT, ZConstant.COLUMNNAME);
						ZExpression expr3 = new ZExpression(ZExpression.EQ, c3, c4);
						//expr = conjoin(expr, new ZExpression(ZExpression.OR, exprLoc, expr3));
						if(comparable){
							expr = conjoin(expr, exprLoc);
						}else{
							expr = conjoin(expr, expr3);
						}
					}
				}
			} else // Skolem -- shouldn't matter for now
			{
				l += ModelConstants.LABEL_NULL_EXT;
				String str = skolemExpr((ScMappingAtomValSkolem)val);
				ZConstant c1 = new ZConstant(l, ZConstant.COLUMNNAME);
				ZConstant c2 = new ZConstant(str, ZConstant.COLUMNNAME);
				if(comparable){
					expr = conjoin(expr, new ZExpression(ZExpression.EQ, c1, c2));
				}else{
					expr = conjoin(expr, hack(c1,c2));
				}
			}
		}
    	return expr;
    }
    
    protected ZExpression buildWhere(Map<ScField, String> typesMap) {
        ZExpression expr = null;
        for (int i = 0; i < getBody().size(); i++) 
        {
        	ScMappingAtom a = getBody().get(i);
        	if(!a.isNeg()){
        		expr = buildWhereForAtom(a, i, _varmap, expr);
        	} else { // Negated atom -- not exists
        		ZQuery n = new ZQuery();
        		HashMap<String,String> atomMap = buildVarMapForAtom(a, i, null, true);
        		n.addSelect(buildSelectForAtom(a, atomMap, typesMap, false));
        		Vector<ZFromItem> v = new Vector<ZFromItem>();
        		v.add(buildFromItem(a, i));
        		n.addFrom(v);
        		n.addWhere(buildWhereForAtom(a, i, _varmap, null));
        		expr = conjoin(expr, new ZExpression(ZExpression.NOT, new ZExpression(ZExpression.EXISTS, n)));
        	}
        }
        return expr;
    }
    
    protected Vector<ZSelectItem> buildSelectForAtom(ScMappingAtom a, Map<String, String> varmap, Map<ScField, String> typesMap, boolean keysAndNulls) {
    	 Vector<ZSelectItem> vs = new Vector<ZSelectItem>();
    	 Vector<ZSelectItem> vsNull = new Vector<ZSelectItem>();
         for (int i = 0; i < a.getValues().size(); i++) {
         	
        	ScMappingAtomValue val = a.getValues().get(i);
         	String fieldName = a.getRelation().getField(i).getName();
         	String labNullFieldName = fieldName + ModelConstants.LABEL_NULL_EXT;
         	
             if (val instanceof ScMappingAtomValVariable) 
             {
                 String col = varmap.get(val.toString());
                 boolean fldInKey = a.getRelation().getPrimaryKey().getFields().contains(a.getRelation().getField(i));
                 if(keysAndNulls && onlyKeyAndNulls() && !fldInKey) //!fieldName.equals("KID"))
                 {
                	 vs.add(typedNull(a.getRelation().getField(i), false, typesMap));
                	 //vsNull.add(typedNull(a.getRelation().getField(i), true, typesMap));
                	 vsNull.add(aliasedSelect(col + ModelConstants.LABEL_NULL_EXT, labNullFieldName, false));
                 }else if(onlyKeyAndNulls()){
                	 vs.add(aliasedSelect(col, fieldName, false));
                	 vsNull.add(aliasedSelect(col + ModelConstants.LABEL_NULL_EXT, labNullFieldName, false));
                 }else{
                	 vs.add(aliasedSelect(col, fieldName, false));
                	 vsNull.add(aliasedSelect(col, labNullFieldName, true));
                 }
             } 
             else if (val instanceof ScMappingAtomValConst) 
             {
            	 if (((ScMappingAtomValConst) val).getValue()!=null){
            		 vs.add(aliasedSelect(val.toString(), fieldName, false));
            	 }else{
            		 vs.add(typedNull(a.getRelation().getField(i), false, typesMap));
            	 }
            	 // Set lab. null to -1
            	 vsNull.add(typedNull(a.getRelation().getField(i), true, typesMap));
            	 
             } else {
                 vs.add(typedNull(a.getRelation().getField(i), false, typesMap));
                 String str = skolemExpr((ScMappingAtomValSkolem)val);
                 vsNull.add(aliasedSelect(str, labNullFieldName, true));
             }            
         }
         vs.addAll(vsNull);
         return vs;
    }
    
    protected Vector<ZSelectItem> buildSelect(Map<ScField, String> typesMap) {
        return buildSelectForAtom(getHead(), _varmap, typesMap, true);
    }
    
   
	protected ZSelectItem typedNull(ScField field, boolean useNLExt, Map<ScField, String> typesMap) {
		ZSelectItem s;
		    if(useNLExt){
		        s = new ZSelectItem("-1");
			}else{
				String t = typesMap.get(field);
			    s = new ZSelectItem("cast(null as " + typesMap.get(field) + ")" );
			}
		s.setAlias(field.getName());
		return s;
		
//		return aliasedSelect("cast(null as " 
//        						+ (useNLExt?"NUMERIC(10)":typesMap.get(field))         						
//        						+ ")", field.getName() + (useNLExt?ModelConstants.LABEL_NULL_EXT:""), true);
    }
    
    
    
    protected static ZSelectItem aliasedSelect(String name, String alias, boolean isLabNull) {
        ZSelectItem s;
        
        if(isLabNull){
	        s = new ZSelectItem("CASE WHEN " + name + " IS NOT NULL THEN 1 ELSE -1 END");
	        s.setAlias(alias);
        }else{
	        s = new ZSelectItem(name);
	        s.setAlias(alias);        	
        }
        return s;
    }
    
    
    protected ZExpression conjoin(ZExpression expr, ZExpression cond) {
        if (expr == null) {
            return cond;
        } else if (cond == null) {
            return expr; 
        } else {
            return new ZExpression(ZExpression.AND, expr, cond);
        }
    }

    
