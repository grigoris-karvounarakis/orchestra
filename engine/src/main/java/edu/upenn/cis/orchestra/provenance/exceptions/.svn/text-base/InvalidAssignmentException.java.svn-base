package edu.upenn.cis.orchestra.provenance.exceptions;

public class InvalidAssignmentException extends Exception {

	public static final long serialVersionUID = 1L;
	
	public InvalidAssignmentException ()
	{
		super ();
	}
	
	public InvalidAssignmentException (String msg)
	{
		super ("Invalid value assignment in provenance query for relation " + msg);
	}
	
}
