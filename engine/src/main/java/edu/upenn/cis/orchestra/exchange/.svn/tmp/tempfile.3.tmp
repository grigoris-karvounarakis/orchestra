	/**
     * Creates the set of delta rules for the system
     */
	public void computeDeltaRules(final boolean DRed) {
		if (_provenancePrep == null)
			_provenancePrep = createProvenanceStorage();
		
		// Cache data in the first peer/first schema...
		final Peer cachePeer = _system.getPeers().iterator().next();
		final Schema cacheSchema = cachePeer.getSchemas().iterator().next();
		cacheSchema.getRelations().iterator().next().getDbCatalog();
		cacheSchema.getRelations().iterator().next().getDbSchema();

		if (Config.getInsert())
			_insRuleGen = new InsertionDeltaRuleGen(_system, DRed);
		
		if (Config.getDelete())
			_delRuleGen = new DeletionDeltaRuleGen(_system, DRed);
		
	}	

    protected void mergeMappingRules(List<Mapping> inputRules, List<Rule>mappingRules, List<Mapping> mappingProjections, IDb db){
	
		// Cache data in the first peer/first schema...
		//final Peer cachePeer = 
		_system.getPeers().iterator().next();

		for(int i = 0; i < inputRules.size(); i++){
       		Mapping mapping = inputRules.get(i);
    		
    		List<AtomVariable> allVars = mapping.getAllBodyVariables();
    		List<AtomArgument> allVarsCast = new ArrayList<AtomArgument> (allVars.size());
    		for (AtomVariable var : allVars)
    			allVarsCast.add(var);
            
    		RelationContext relCtx = getMappingRelations().get(i);
    		
    		Atom newHead = new Atom(relCtx, allVarsCast);
            
    		List<Atom> ruleBody = new ArrayList<Atom>();
			for(Atom ma : mapping.getBody()){
				ruleBody.add(new Atom(ma.getRelationContext(), ma.getValues()));
			}

			// Don't create any rules with built-in relations in the head
			// (And likewise don't create projection rules from these)
			if (!getMappingDb().isBuiltInAtom(newHead)) {
				mappingRules.add(new Rule(newHead, ruleBody, _system.getMappingDb()));
            
				List<Atom> projBody = new ArrayList<Atom>();
				projBody.add(newHead);
	
				List<Atom> projHead = new ArrayList<Atom>();
				for(Atom ma : mapping.getMappingHead()){
					projHead.add(ma.deepCopy());
				}
				
				Mapping proj = new Mapping("MH-PROJ"+i, "MH-PROJ"+i, true, 1, projHead, projBody);
			        
	            mappingProjections.add(proj);
			}
    	}	
    }

	/**
	 * Creates a set of translation rules
	 * 
	 * @param dao
	 * @return
	 */

    public List<Rule> computeTranslationRules() throws Exception {

    	try{
    		List<Mapping> mappings = _system.getAllSystemMappings(true);
    		for(Mapping m : mappings){
    			m.renameExistentialVars();
    		}
    		List<RelationContext>_rels = _system.getAllUserRelations();

    		_state = new TranslationState(mappings, _rels);

    		Debug.println ("Mappings: " + mappings.size());

    		Calendar before = Calendar.getInstance();

    		List<Rule> rules;
    		//List<Rule> baseRules;
    		List<Rule> inOutRulesIns;
    		//List<Rule> inOutRulesDel;

//  		_edbs = new ArrayList<RelationContext>();
//  		_idbs = new ArrayList<RelationContext>();

//  		List<RelationContext>_rels = _system.getAllUserRelations();

//  		mappings.addAll(MappingsIOMgt.inOutTranslationL(_system, _rels));

    		getState().setLocal2PeerRules(MappingsIOMgt.inOutTranslationL(_system, _rels));
    		mappings.addAll(getState().getLocal2PeerRules());
    		getState().setMappings(mappings);

    		if(!Config.getOuterUnion()){
    			List<Rule> mergedHeads = new ArrayList<Rule>();
    			List<Mapping> projections = new ArrayList<Mapping>();

//  			Repeated in migrate	
    			getState().setMappingRels(createProvenanceTables(false, mappings));//true);

    			mergeMappingRules(mappings, mergedHeads, projections, _system.getMappingDb());

    			rules = MappingsInversionMgt.inverseMappings(projections, _system.getMappingDb());

    			inOutRulesIns = MappingsIOMgt.inOutTranslationR(_system, rules, true);

    			MappingsCompositionMgt.compose(inOutRulesIns);

    			getState().setBaseDelRules(MappingsInversionMgt.inverseMappings(mappings, _system.getMappingDb()));
    			MappingsCompositionMgt.compose(getState().getBaseDelRules());

    			getState().setMappingRules(mergedHeads);
    			getState().setMappingProjectionRules(inOutRulesIns);

    			getState().setBaseInsRules(inOutRulesIns);
    			getState()._projectionsBeforeInversion = projections;
    		}else{
    			rules = MappingsInversionMgt.inverseMappings(mappings, _system.getMappingDb());

//  			Repeated in migrate			
    			_state._mappingRels = createOUProvenanceTables(false, rules);//true);

    			inOutRulesIns = MappingsIOMgt.inOutTranslationR(_system, rules, true);

    			MappingsCompositionMgt.compose(inOutRulesIns);

    			_state.setBaseInsRules(inOutRulesIns);
    			_state._baseDelRules = inOutRulesIns;

    			_system.getMappingEngine().calcOuMappingRules();
    			Debug.println("");
    		}

    		Calendar after = Calendar.getInstance();
    		long time = after.getTimeInMillis() - before.getTimeInMillis();
    		Debug.println("TOTAL RULE MANIPULATION TIME: " + time + "msec");

//  		List<Rule> ret = new ArrayList<Rule>();

//  		try{
//  		foo();
//  		}catch(Exception e){

//  		}
    		return inOutRulesIns;
    	}catch(Exception e){
    		e.printStackTrace();
    		throw(e);
    		//return null;
    	}
    }
	
