	/**
		 * Computes the names of all of the tables in the Orchestra system.
		 * Package-level because it's SQL-specific
		 * 
		 * @param syst
		 * @param includeMappings: include the mapping relations
		 * @param includeDeltas: include the delta relations
		 * @param includeBase: include the base relations
		 */
		public static List<String> getNamesOfAllTables(final OrchestraSystem syst, 
				final boolean includeMappings,
				final boolean includeDeltas, final boolean includeBase) {
			final ArrayList<String> tables = new ArrayList<String>();
			
			for (final Peer p : syst.getPeers())
				for (final Schema sc : p.getSchemas())
					for (final Relation rel : sc.getRelations())
					{
						if (includeBase)
							tables.add(rel.getFullQualifiedDbId());
						
						if (includeDeltas)
							for (final Atom.AtomType type : Atom.AtomType.values()){
								String suffix = Atom.typeToString(type);
								
								//if((rel.getFullQualifiedDbId().endsWith("_L") || rel.getFullQualifiedDbId().endsWith("_R"))
								if (rel.isInternalRelation()
										&& type != AtomType.RCH){

								}else{
									if(!suffix.equals("")){
										suffix = "_" + suffix;
									}

									//							tables.add(rel.getFullQualifiedDbId() + "_" + type.toString());
									tables.add(rel.getFullQualifiedDbId() + suffix);
								}
							}
						}

			if(syst.getMappingEngine() != null && syst.getMappingEngine().getMappingRelations() != null){
				for(RelationContext rel : syst.getMappingEngine().getMappingRelations()){

					for (final Atom.AtomType type : Atom.AtomType.values()) {
						String suffix = Atom.typeToString(type);

						if(type != AtomType.RCH){
							if(!suffix.equals("")){
								suffix = "_" + suffix;
							}

							tables.add((rel.getRelation().getDbSchema()==null?"": rel.getRelation().getDbSchema()+".")
									+ rel.getRelation().getName() + suffix
							);
						}
					}
				}
			}else{
//				Translation state not set yet ...
//				Still, I don't think I need e.g., inverse here
				if (includeMappings){
					final List<Mapping> mappings = syst.getAllSystemMappings(true);
					final List<Rule> rules = MappingsInversionMgt.inverseMappings(mappings, syst.getMappingDb());
					MappingsCompositionMgt.compose(rules);

					for (int  i = 0 ;  i < rules.size() ; i++)
					{
						final Rule r = rules.get(i);
						final Relation rel = r.getHead().getRelation();
						//				tables.add((rel.getDbSchema()!=null?rel.getDbSchema() + ".":"")
						//						+ rel.getDbRelName() + "M" + i);

						for (final Atom.AtomType type : Atom.AtomType.values()) {
							String suffix = Atom.typeToString(type);

							if(type != AtomType.RCH){
								if(!suffix.equals("")){
									suffix = "_" + suffix;
								}

								tables.add((rel.getDbSchema()==null?"": rel.getDbSchema()+".")
										+ "M" + i + suffix
								);
							}
						}
					}
				}
			}
			return tables;
		}

	public static List<String> getNamesOfAllTablesFromDeltas(/*DeltaRules deltas,*/ final OrchestraSystem syst, boolean allTypes, boolean includeMappings){
//		ArrayList<RelationContext> tables = new ArrayList<RelationContext>();
		HashMap<RelationContext, Integer> tables = new HashMap<RelationContext, Integer>();
		
		for(RelationContext rel : syst.getMappingEngine().getEdbs()){	
			tables.put(rel, 0);
		}
		
		for(RelationContext rel : syst.getMappingEngine().getIdbs()){	
			tables.put(rel, 1);
		}
		
		if(includeMappings){
			for(RelationContext rel : syst.getMappingEngine().getMappingRelations()){
				if(!tables.containsKey(rel))
					tables.put(rel, 2);
			}
		}
		
		List<String> names = new ArrayList<String>();
		for(RelationContext rel : tables.keySet()){
			
			if(allTypes){
				for (final Atom.AtomType type : Atom.AtomType.values()){
					String suffix = Atom.typeToString(type);
					
					if(((tables.get(rel) == 1) || (type != AtomType.RCH)) &&
							(!Config.getStratified() || type != AtomType.ALLDEL)){
						if(!suffix.equals("")){
							suffix = "_" + suffix;
						}
						if(!names.contains(rel.getRelation().getFullQualifiedDbId() + suffix))	
							names.add(rel.getRelation().getFullQualifiedDbId() + suffix);
					}
				}
			}else{
				if(!names.contains(rel.getRelation().getFullQualifiedDbId()))	
					names.add(rel.getRelation().getFullQualifiedDbId());
			}		
		}
		
//		for (final Peer p : syst.getPeers())
//		{
//			for (final Schema sc : p.getSchemas())
//			{
//				for (final TableSchema rel : sc.getRelations())
//				{	
//					if (!names.contains(rel.getFullQualifiedDbId()))
//					{
////						if(includeMappings || !deltas.getMappingRelations().contains(new RelationContext(rel, sc, p))){
//						if(includeMappings && !deltas.getMappingRelations().contains(new RelationContext(rel, sc, p, true))){
//							for (final ScMappingAtom.AtomType type : ScMappingAtom.AtomType.values())
//							{
//								String suffix = ScMappingAtom.typeToString(type);
//	
//								if((type != AtomType.RCH) && 
//										(!Config.DO_STRATIFIED || type != AtomType.ALLDEL)){
//									if(!suffix.equals("")){
//										suffix = "_" + suffix;
//									}
//									if(!names.contains(rel.getFullQualifiedDbId() + suffix))
//										names.add(rel.getFullQualifiedDbId() + suffix);
//								}
//							}
//						}
//					}
//				}
//			}
//		}
//
////		I think this should not be necessary in either case - but anyway only works 
////		for outer union because it involves inverse rules before counting the mappings ...
//		if(Config.DO_OUTER_UNION){
//			if(includeMappings){
//				final List<ScMapping> mappings;
//				final List<Rule> rules;
//
//				mappings = syst.getAllSystemMappings(true);
//				rules = MappingsInversionMgt.inverseMappings(mappings);
//				MappingsCompositionMgt.compose(rules);
//
//				for (int  i = 0 ;  i < rules.size() ; i++)
//				{
//					final Rule r = rules.get(i);
//					final TableSchema rel = r.getHead().getRelation();
//
//					String name;
//
//					if(Config.DO_OUTER_UNION){
//						name = rel.getFullQualifiedOUProvDbId();
//					}else{
//						name = (rel.getDbSchema()==null?"": rel.getDbSchema()+".") + "M" + i;
//					}
//
//					if (!names.contains(name)){
//
//						for (final ScMappingAtom.AtomType type : ScMappingAtom.AtomType.values()) {
//							String suffix = ScMappingAtom.typeToString(type);
//
