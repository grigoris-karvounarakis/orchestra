	public BasicEngine(IDb mappingDb, 
//			IDb updateDb, 
			OrchestraSystem system, boolean
			generateRules) throws Exception {
		_mappingDb = mappingDb;
//		_updateDb = updateDb;
		_system = system;
		if (_system.getMappingEngine() == null)
			_system.setMappingEngine(this);
		
		if (generateRules) {
			_system.setMigrated();
			computeTranslationRules();
			computeDeltaRules();
		}
	}

