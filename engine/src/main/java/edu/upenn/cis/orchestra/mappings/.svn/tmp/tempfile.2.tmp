	public Rule (ScMappingAtom head, ScMappingAtom b)
	{
		super(head.deepCopy(), b.deepCopy());
		_code = new RuleSqlGen(this);
	}
	
	public Rule (ScMappingAtom head, List<ScMappingAtom> body)
	{
		_code = new RuleSqlGen(this);
		_head.add(head.deepCopy());
		for (ScMappingAtom atom : body)
			_body.add(new ScMappingAtom(atom).deepCopy());
	}

	public Rule (ScMappingAtom head, List<ScMappingAtom> body, boolean onlyKeyAndNulls)
	{
		this (head, body);
		_code = new RuleSqlGen(this);
		_onlyKeyAndNulls = onlyKeyAndNulls;
		//_onlyKeyAndNulls = false;
	}
	
	/**
	 * Get the rule's head 
