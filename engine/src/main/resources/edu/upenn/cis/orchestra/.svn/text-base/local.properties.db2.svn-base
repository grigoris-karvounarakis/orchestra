# Apply SQL to DBMS
apply=true

# Put multiple queries in one batch
batch=false

# Use autocommit
autocommit=false

# Create deletion rules
delete=true

# Debug mode
debug=true

# Create insertion rules
insert=true

# Do incremental maintenance (false overrides insert, delete options)
incremental=true

# Create outer unions, versus individual mapping relations
outerunion=true

# Prepare statements before executing
prepare=true

# Reset the tables at the end
reset=true

# Put rules with the same body in one union query
union=false

# Index all fields
indexall=true

# URL for DB2 server
db2server=jdbc:db2:VLDB

# local dbname
dbname=VLDB

# Username for DB2
db2user=gkarvoun

# Password for DB2
db2pwd=GREG#00

# Schema file prefix
schema=2p1n

# Workload files prefix
workload=2p1n-100i10d

# Directory with workload and schema files
workdir=/dev/orchestra/experiments/tests

# Estimated table size
tablesize=0

# JDBC driver to use
jdbc-driver=COM.ibm.db2.jdbc.app.DB2Driver

# Cygwin root directory
cygwinhome=C:/cygwin
