PEERS
	PEER P dbserv.cis.upenn.edu:5000 "DB group database server"
		SCHEMAS
			SCHEMA schema2 "This is schema 2"
				RELATIONS
					RELATION T3 "T3" MATERIALIZED <<0>>
						DBINFO , SCHEMA2, T3
						FIELDS A INTEGER 10 NOT NULL, B INTEGER 10 NOT NULL, C INTEGER 10 NULL

					RELATION T1 "T1" MATERIALIZED <<0>>
						DBINFO , SCHEMA2, T1
						FIELDS A INTEGER 10 NOT NULL, B INTEGER 10 NOT NULL, C VARCHAR VARCHAR(30) 30 NOT NULL, D VARCHAR VARCHAR(30) 30 NOT NULL

					RELATION T2 "T2" MATERIALIZED <<0>>
						DBINFO , SCHEMA2, T2
						FIELDS A INTEGER 10 NOT NULL, B INTEGER 10 NOT NULL, C VARCHAR VARCHAR(30) 30 NOT NULL, D VARCHAR VARCHAR(30) 30 NOT NULL

			SCHEMA schema1 "This is schema 1"
				RELATIONS
					RELATION T3 "T3" MATERIALIZED <<0>>
						DBINFO , SCHEMA1, T3
						FIELDS A INTEGER 10 NOT NULL, B INTEGER 10 NOT NULL, C INTEGER 10 NULL
						PRIMARY KEY T3_PK(A) <<0>>

					RELATION T1 "T1" MATERIALIZED <<0>>
						DBINFO , SCHEMA1, T1
						FIELDS A INTEGER 10 NOT NULL, B INTEGER 10 NOT NULL, C VARCHAR VARCHAR(30) 30 NOT NULL, D VARCHAR VARCHAR(30) 30 NOT NULL
						PRIMARY KEY T1_PK(A) <<0>>

					RELATION T2 "T2" MATERIALIZED <<0>>
						DBINFO , SCHEMA1, T2
						FIELDS A INTEGER 10 NOT NULL, B INTEGER 10 NOT NULL, C VARCHAR VARCHAR(30) 30 NOT NULL, D VARCHAR VARCHAR(30) 30 NOT NULL
						PRIMARY KEY T2_PK(A, B) <<0>>
		MAPPINGS
			M1 MATERIALIZED: P.schema1.T1(x,y,z,'CST'):-P.schema2.T3(x,y,z)
			M2 MATERIALIZED: P.schema1.T2(x,y,z,t):-P.schema1.T3(x,y,u), P.schema2.T1(u,t,'CST','XST')