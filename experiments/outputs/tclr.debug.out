+++ Mappings +++
M2 MATERIALIZED: P.S.T(x_,z_) :- P.S.E(x_,y_),P.S.T(y_,z_)
M1 MATERIALIZED: P.S.T(x_,y_) :- P.S.E(x_,y_)
+++ Inverted/Composed Mappings with Provenance Relations +++
Mappings: 2
TOTAL RULE MANIPULATION TIME: 16msec
P.S.T(x__,z__) :- P.S.M0(x__,y__,z__), not(P.S.T_R(x__,z__))  
P.S.T(x__,y__) :- P.S.M1(x__,y__), not(P.S.T_R(x__,y__))  
P.S.E(X1_,X2_) :- P.S.M2(X1_,X2_), not(P.S.E_R(X1_,X2_))  
P.S.T(X3_,X4_) :- P.S.M3(X3_,X4_), not(P.S.T_R(X3_,X4_))  
