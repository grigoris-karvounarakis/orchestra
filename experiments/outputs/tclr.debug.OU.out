M2 MATERIALIZED: P.S.T(x_,z_) :- P.S.E(x_,y_),P.S.T(y_,z_)
M1 MATERIALIZED: P.S.T(x_,y_) :- P.S.E(x_,y_)
+++ Inverted/Composed Mappings with Provenance Relations +++
Mappings: 2
ProvE([[E_L.x]], [[E_L.y]])
ProvT([[E.x], [E.x], [T_L.x]], [[E.y]], [[T.y], [E.y], [T_L.y]])
TOTAL RULE MANIPULATION TIME: 109msec
P.S.T(GREG_0,GREG_1) :- P.S.E(GREG_0,y__1), P.S.T(y__1,GREG_1), not(P.S.T_R(GREG_0,GREG_1))  
P.S.T(GREG_0,GREG_1) :- P.S.E(GREG_0,GREG_1), not(P.S.T_R(GREG_0,GREG_1))  
P.S.E(GREG_0,GREG_1) :- P.S.E_L(GREG_0,GREG_1), not(P.S.E_R(GREG_0,GREG_1))  
P.S.T(GREG_0,GREG_1) :- P.S.T_L(GREG_0,GREG_1), not(P.S.T_R(GREG_0,GREG_1))  
